{
	"name": "full_browser_excalidraw_example",
	"version": "1.0.0",
	"description": "Full-viewport Excalidraw demo built with pict-section-excalidraw",
	"retold": {
		"ExampleApplication": {
			"Stage": true,
			"Title": "Full-Browser Excalidraw",
			"Summary": "A full-viewport Excalidraw workspace built from pict-section-excalidraw — the maximal embed where the drawing surface owns the whole window.",
			"Complexity": "Beginner",
			"SharedVendor": {
				"Key": "excalidraw",
				"Scripts": [ "react-vendor.min.js", "excalidraw-wrapper.min.js" ],
				"Styles": [ "excalidraw-wrapper.css" ],
				"AssetDirs": [ "excalidraw-assets" ]
			}
		}
	},
	"main": "FullBrowserExcalidraw-Example-Application.js",
	"scripts": {
		"start": "node FullBrowserExcalidraw-Example-Application.js",
		"build": "npx quack build && npx quack copy"
	},
	"author": "steven",
	"license": "MIT",
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{ "from": "./html/*",                                            "to": "./dist/" },
		{ "from": "../../node_modules/pict/dist/*",                      "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/react-vendor.min.js",   "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/excalidraw-wrapper.min.js", "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/excalidraw-wrapper.css",    "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/assets/**/*",           "to": "./dist/excalidraw-assets/" }
	],
	"dependencies": {
		"pict": "^1.0.348",
		"pict-application": "^1.0.19",
		"pict-view": "^1.0.66"
	}
}
