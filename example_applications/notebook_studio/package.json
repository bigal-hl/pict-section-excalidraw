{
	"name": "notebook_studio_example",
	"version": "1.0.0",
	"description": "Studio for hand-crafting notebook-style Excalidraw diagrams via DSL, AI prompt, or JSON paste",
	"retold": {
		"ExampleApplication": {
			"Stage": true,
			"Title": "Notebook Studio",
			"Summary": "A studio for hand-crafting notebook-style diagrams via a small DSL, an AI prompt, or pasted JSON — rendered live through the bespoke notebook generator. The richest example.",
			"Complexity": "Advanced",
			"SharedVendor": {
				"Key": "excalidraw",
				"Scripts": [ "react-vendor.min.js", "excalidraw-wrapper.min.js" ],
				"Styles": [ "excalidraw-wrapper.css" ],
				"AssetDirs": [ "excalidraw-assets" ]
			}
		}
	},
	"main": "Notebook-Studio-Application.js",
	"scripts": {
		"start": "node Notebook-Studio-Application.js",
		"build": "npx quack build && npx quack copy"
	},
	"author": "steven",
	"license": "MIT",
	"copyFilesSettings":
	{
		"whenFileExists": "overwrite"
	},
	"copyFiles":
	[
		{ "from": "./html/*",                                            "to": "./dist/" },
		{ "from": "../../node_modules/pict/dist/*",                      "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/react-vendor.min.js",   "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/excalidraw-wrapper.min.js", "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/excalidraw-wrapper.css",    "to": "./dist/" },
		{ "from": "../../vendor/excalidraw-built/assets/**/*",           "to": "./dist/excalidraw-assets/" }
	],
	"dependencies":
	{
		"pict": "^1.0.348",
		"pict-application": "^1.0.19",
		"pict-view": "^1.0.66"
	}
}
